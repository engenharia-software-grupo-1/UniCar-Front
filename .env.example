# URL base da API de backend (US6/US7). Padrão: http://localhost:8080
VITE_API_URL=http://localhost:8080

# Liga/desliga TODOS os mocks (rede via MSW + dados locais em localStorage).
# Vale tanto em `npm run dev` quanto no build.
#
#   false → modo backend: os serviços batem na API real
#           (em dev, via proxy do vite.config.js; no build, via VITE_API_URL).
#           Requer o backend rodando em VITE_API_URL.
#
#   true  → modo offline: MSW intercepta a rede e os serviços de veículos,
#           caronas e avaliações devolvem dados do localStorage. Não precisa
#           de backend. Use para desenvolver/demonstrar a UI isoladamente.
VITE_ENABLE_MOCKS=false
